    "# ── Top 5 Risk Drivers per Loan (Production Output) ─────────────────────────\n",
    "def get_top_risk_drivers(shap_vals, feature_names, feature_values, n=5):\n",
    "    \"\"\"\n",
    "    Production function: returns top N SHAP risk drivers for a single loan.\n",
    "    Used by FastAPI /predict endpoint.\n",
    "    \"\"\"\n",
    "    sorted_idx = np.argsort(np.abs(shap_vals))[::-1][:n]\n",
    "    drivers = []\n",
    "    for rank, i in enumerate(sorted_idx, 1):\n",
    "        drivers.append({\n",
    "            'rank': rank,\n",
    "            'feature': feature_names[i],\n",
    "            'value': float(round(feature_values[i], 4)),\n",
    "            'shap_impact': float(round(shap_vals[i], 4)),\n",
    "            'direction': 'INCREASES_RISK' if shap_vals[i] > 0 else 'DECREASES_RISK'\n",
    "        })\n",
    "    return drivers\n",
    "\n",
    "# Demo on the high-risk loan\n",
    "drivers = get_top_risk_drivers(shap_values[high_risk_idx], ALL_FEATURES, X_shap[high_risk_idx])\n",
    "print(f\"\\n Top 5 Risk Drivers for High-Risk Loan (prob={y_shap_probs[high_risk_idx]:.1%}):\")\n",
    "print(\"-\" * 70)\n",
    "for d in drivers:\n",
    "    arrow = '⬆️' if d['direction'] == 'INCREASES_RISK' else '⬇️'\n",
    "    print(f\"  #{d['rank']} {arrow} {d['feature']:<40} value={d['value']:.3f}  SHAP={d['shap_impact']:+.4f}\")\n",
    "\n",
    "# Store SHAP explainer and values  \n",
    "shap_expected_value = explainer.expected_value\n",
    "print(f\"\\n SHAP base value (expected log-odds): {shap_expected_value:.4f}\")\n"
   ]
