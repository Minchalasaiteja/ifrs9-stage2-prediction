    "# ── Helper: evaluate_model_from_probs (for ensemble + test eval) ────────────\n",
    "def evaluate_model_from_probs(y_prob, y, threshold=0.5, model_name='Model'):\n",
    "    \"\"\"Evaluate model from pre-computed probabilities.\"\"\"\n",
    "    import numpy as np\n",
    "    from sklearn.metrics import (roc_auc_score, average_precision_score,\n",
    "                                  brier_score_loss, recall_score, precision_score, f1_score)\n",
    "    y_arr = np.array(y)\n",
    "    y_pred = (y_prob >= threshold).astype(int)\n",
    "    roc    = roc_auc_score(y_arr, y_prob)\n",
    "    pr_auc = average_precision_score(y_arr, y_prob)\n",
    "    brier  = brier_score_loss(y_arr, y_prob)\n",
    "    rec    = recall_score(y_arr, y_pred, zero_division=0)\n",
    "    prec   = precision_score(y_arr, y_pred, zero_division=0)\n",
    "    f1     = f1_score(y_arr, y_pred, zero_division=0)\n",
    "    n_top  = int(len(y_arr) * 0.10)\n",
    "    top_idx = np.argsort(y_prob)[::-1][:n_top]\n",
    "    recall_top10 = y_arr[top_idx].sum() / max(y_arr.sum(), 1)\n",
    "    captured = y_arr[top_idx].sum() / max(y_arr.sum(), 1) * 100\n",
    "    return {\n",
    "        'model': model_name, 'roc_auc': round(roc,4), 'pr_auc': round(pr_auc,4),\n",
    "        'brier': round(brier,4), 'recall': round(rec,4), 'precision': round(prec,4),\n",
    "        'f1': round(f1,4), 'recall_top10pct': round(recall_top10,4),\n",
    "        'captured_stage2_top10pct': round(captured,2)\n",
    "    }, y_prob\n",
    "\n",
    "print(\" evaluate_model_from_probs defined\")\n"
   ]
