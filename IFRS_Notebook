    "# ── Chronological Split ──────────────────────────────────────────────────────\n",
    "def quarter_to_num_simple(q):\n",
    "    year, qtr = q.split('-Q')\n",
    "    return (int(year) - 2021) * 4 + int(qtr)\n",
    "\n",
    "df_feat['qnum'] = df_feat['assessment_date'].apply(quarter_to_num_simple)\n",
    "\n",
    "# Split boundaries\n",
    "TRAIN_END  = quarter_to_num_simple('2023-Q3')   # inclusive\n",
    "VAL_END    = quarter_to_num_simple('2024-Q2')    # inclusive\n",
    "TEST_START = quarter_to_num_simple('2024-Q3')    # inclusive\n",
    "\n",
    "train_mask = df_feat['qnum'] <= TRAIN_END\n",
    "val_mask   = (df_feat['qnum'] > TRAIN_END) & (df_feat['qnum'] <= VAL_END)\n",
    "test_mask  = df_feat['qnum'] >= TEST_START\n",
    "\n",
    "df_train = df_feat[train_mask].copy()\n",
    "df_val   = df_feat[val_mask].copy()\n",
    "df_test  = df_feat[test_mask].copy()\n",
    "\n",
    "X_train = df_train[ALL_FEATURES]\n",
    "y_train = df_train[TARGET]\n",
    "X_val   = df_val[ALL_FEATURES]\n",
    "y_val   = df_val[TARGET]\n",
    "X_test  = df_test[ALL_FEATURES]\n",
    "y_test  = df_test[TARGET]\n",
    "\n",
    "print(\"=\" * 55)\n",
    "print(f\"{'Split':<12} {'Quarters':<22} {'Rows':>8} {'Stage2%':>8}\")\n",
    "print(\"-\" * 55)\n",
    "for name, df_s, y_s, qr in [\n",
