    "# ── Feature Engineering Pipeline ────────────────────────────────────────────\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "\n",
    "def engineer_features(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Production Feature Engineering for IFRS 9 Stage 2 Prediction\n",
    "    \"\"\"\n",
    "\n",
    "    d = df.copy()\n",
    "\n",
    "    # ==========================================================\n",
    "    # 1. Replace Sentinel Values\n",
    "    # ==========================================================\n",
    "    SENTINELS = {\n",
    "        \"loan_to_value_pct\": [-1.0],\n",
    "        \"credit_score_change_last_quarter\": [-1],\n",
    "        \"utilisation_rate_pct\": [-1.0],\n",
    "        \"property_value_change_pct_last_qtr\": [-999.0],\n",
    "        \"ltv_change_pct_since_origination\": [-999.0],\n",
    "        \"origination_ltv_pct\": [-1.0],\n",
    "        \"pd_relative_change_pct\": [-1.0],\n",
    "    }\n",
    "\n",
    "    for col, vals in SENTINELS.items():\n",
    "        if col in d.columns:\n",
    "            d[col] = d[col].replace(vals, np.nan)\n",
    "\n",
    "    # ==========================================================\n",
    "    # 2. Binary Encoding\n",
    "    # ==========================================================\n",
    "    binary_yes_no = [\n",
    "        \"is_fixed_rate\",\n",
    "        \"has_other_credit_with_bank\",\n",
    "        \"payment_reduction_requested\",\n",
    "        \"forbearance_history\",\n",
    "        \"sector_stress_flag\",\n",
    "        \"is_restructured_loan\",\n",
    "        \"early_repayment_flag\",\n",
    "        \"current_account_debit_flag\",\n",
    "    ]\n",
    "\n",
    "    for col in binary_yes_no:\n",
    "        if col in d.columns:\n",
    "            d[f\"{col}_enc\"] = (\n",
    "                d[col]\n",
    "                .fillna(\"No\")\n",
    "                .astype(str)\n",
    "                .str.strip()\n",
    "                .str.lower()\n",
    "                .eq(\"yes\")\n",
    "                .astype(int)\n",
    "            )\n",
    "\n",
    "    # ==========================================================\n",
    "    # 3. DPD Features\n",
    "    # ==========================================================\n",
    "    d[\"is_delinquent\"] = (d[\"days_past_due_current\"].fillna(0) > 0).astype(int)\n",
    "\n",
    "    d[\"dpd_bucket\"] = (\n",
    "        pd.cut(\n",
    "            d[\"days_past_due_current\"],\n",
    "            bins=[-1, 0, 7, 14, 21, 28, np.inf],\n",
    "            labels=False,\n",
    "        )\n",
    "        .fillna(0)\n",
    "        .astype(int)\n",
    "    )\n",
    "\n",
    "    d[\"missed_payment_rate\"] = (\n",
    "        d[\"missed_payments_last_12m\"].fillna(0) / 12\n",
    "    )\n",
    "\n",
    "    d[\"payment_stress_score\"] = (\n",
    "        (d[\"days_past_due_current\"].fillna(0) / 30).clip(0, 1) * 0.5\n",
    "        + (d[\"missed_payments_last_12m\"].fillna(0) / 12).clip(0, 1) * 0.3\n",
    "        + d[\"payment_reduction_requested_enc\"] * 0.1\n",
    "        + d[\"forbearance_history_enc\"] * 0.1\n",
    "    )\n",
    "\n",
    "    # ==========================================================\n",
    "    # 4. Credit Quality\n",
    "    # ==========================================================\n",
    "    d[\"credit_score_band\"] = pd.cut(\n",
    "        d[\"internal_credit_score\"],\n",
    "        bins=[0, 580, 620, 680, 740, 800, np.inf],\n",
    "        labels=[0, 1, 2, 3, 4, 5],\n",
    "    ).astype(\"float\")\n",
    "\n",
    "    d[\"score_deteriorating\"] = (\n",
    "        d[\"credit_score_change_last_quarter\"].fillna(0) < 0\n",
    "    ).astype(int)\n",
    "\n",
    "    d[\"score_change_abs\"] = (\n",
    "        d[\"credit_score_change_last_quarter\"]\n",
    "        .fillna(0)\n",
    "        .abs()\n",
    "    )\n",
    "\n",
    "    d[\"bureau_stress\"] = (\n",
    "        d[\"bureau_inquiries_last_6m\"].fillna(0) > 3\n",
    "    ).astype(int)\n",
    "\n",
    "    d[\"credit_stress_score\"] = (\n",
    "        (\n",
    "            1\n",
    "            - d[\"internal_credit_score\"]\n",
    "            .clip(300, 850)\n",
    "            .sub(300)\n",
    "            .div(550)\n",
    "        ).fillna(0.5)\n",
    "        * 0.6\n",
    "        + d[\"score_deteriorating\"] * 0.25\n",
    "        + d[\"bureau_stress\"] * 0.15\n",
    "    )\n",
    "\n",
    "    # ==========================================================\n",
    "    # 5. PD Dynamics\n",
    "    # ==========================================================\n",
    "    d[\"pd_lift\"] = (\n",
    "        d[\"pd_12m_current_pct\"]\n",
    "        - d[\"pd_12m_at_origination_pct\"]\n",
    "    )\n",
    "\n",
    "    d[\"pd_lift_relative\"] = np.where(\n",
    "        d[\"pd_12m_at_origination_pct\"] > 0,\n",
    "        d[\"pd_lift\"] / d[\"pd_12m_at_origination_pct\"],\n",
    "        0,\n",
    "    )\n",
    "\n",
    "    d[\"pd_doubled\"] = (\n",
    "        d[\"pd_lift_relative\"] >= 1\n",
    "    ).astype(int)\n",
    "\n",
    "    d[\"log_pd_current\"] = np.log1p(\n",
    "        d[\"pd_12m_current_pct\"].fillna(0)\n",
    "    )\n",
    "\n",
    "    d[\"log_pd_at_origination\"] = np.log1p(\n",
    "        d[\"pd_12m_at_origination_pct\"].fillna(0)\n",
    "    )\n",
    "\n",
    "    d[\"pd_rel_change_filled\"] = (\n",
    "        d[\"pd_relative_change_pct\"]\n",
    "        .fillna(0)\n",
    "    )\n",
    "\n",
    "    # ==========================================================\n",
    "    # 6. Loan Structure\n",
    "    # ==========================================================\n",
    "    d[\"balance_utilisation\"] = np.where(\n",
    "        d[\"loan_amount_gbp\"] > 0,\n",
    "        d[\"outstanding_balance_gbp\"] / d[\"loan_amount_gbp\"],\n",
    "        np.nan,\n",
    "    )\n",
    "\n",
    "    d[\"amount_repaid_pct\"] = (\n",
    "        1 - d[\"balance_utilisation\"].fillna(0.5)\n",
    "    )\n",
    "\n",
    "    d[\"term_completion_ratio\"] = np.where(\n",
    "        d[\"original_loan_term_months\"] > 0,\n",
    "        1\n",
    "        - (\n",
    "            d[\"remaining_term_months\"]\n",
    "            / d[\"original_loan_term_months\"]\n",
    "        ),\n",
    "        np.nan,\n",
    "    )\n",
    "\n",
    "    d[\"maturity_pressure\"] = np.where(\n",
    "        d[\"remaining_term_months\"] <= 12,\n",
    "        d[\"balance_utilisation\"].fillna(0.5),\n",
    "        0,\n",
    "    )\n",
    "\n",
    "    d[\"ltv_available\"] = (\n",
    "        d[\"loan_to_value_pct\"].notna().astype(int)\n",
    "    )\n",
    "\n",
    "    d[\"ltv_filled\"] = (\n",
    "        d[\"loan_to_value_pct\"].fillna(0)\n",
    "    )\n",
    "\n",
    "    d[\"high_ltv_flag\"] = (\n",
    "        (\n",
    "            d[\"loan_to_value_pct\"].fillna(0) > 80\n",
    "        )\n",
    "        & (d[\"ltv_available\"] == 1)\n",
    "    ).astype(int)\n",
    "\n",
    "    d[\"ltv_deteriorating\"] = (\n",
    "        d[\"ltv_change_pct_since_origination\"]\n",
    "        .fillna(0)\n",
    "        > 5\n",
    "    ).astype(int)\n",
    "\n",
    "    d[\"log_loan_amount\"] = np.log1p(\n",
    "        d[\"loan_amount_gbp\"]\n",
    "    )\n",
    "\n",
    "    d[\"log_outstanding_balance\"] = np.log1p(\n",
    "        d[\"outstanding_balance_gbp\"]\n",
    "    )\n",
    "\n",
    "    # ==========================================================\n",
    "    # 7. Risk Flags\n",
    "    # ==========================================================\n",
    "    d[\"n_risk_flags\"] = (\n",
    "        d[\"is_delinquent\"]\n",
    "        + d[\"is_restructured_loan_enc\"]\n",
    "        + d[\"payment_reduction_requested_enc\"]\n",
    "        + d[\"forbearance_history_enc\"]\n",
    "        + d[\"sector_stress_flag_enc\"]\n",
    "        + d[\"pd_doubled\"]\n",
    "        + d[\"score_deteriorating\"]\n",
    "        + d[\"bureau_stress\"]\n",
    "        + d[\"high_ltv_flag\"]\n",
    "        + d[\"current_account_debit_flag_enc\"]\n",
    "    )\n",
    "\n",
    "    max_log_pd = d[\"log_pd_current\"].max()\n",
    "\n",
    "    if pd.isna(max_log_pd) or max_log_pd <= 0:\n",
    "        max_log_pd = 0.001\n",
    "\n",
    "    d[\"composite_sicr_score\"] = (\n",
    "        0.30 * d[\"payment_stress_score\"]\n",
    "        + 0.25 * d[\"credit_stress_score\"]\n",
    "        + 0.25 * (d[\"log_pd_current\"] / max_log_pd)\n",
    "        + 0.20 * (d[\"n_risk_flags\"] / 10)\n",
    "    )\n",
    "\n",
    "    # ==========================================================\n",
    "    # 8. Time Features\n",
    "    # ==========================================================\n",
    "    def quarter_to_num(q):\n",
    "        try:\n",
    "            year, quarter = str(q).split(\"-Q\")\n",
    "            return (int(year) - 2021) * 4 + int(quarter)\n",
    "        except Exception:\n",
    "            return np.nan\n",
    "\n",
    "    d[\"quarter_num\"] = d[\"assessment_date\"].apply(quarter_to_num)\n",
    "\n",
    "    d[\"vintage_age\"] = (\n",
    "        d[\"quarter_num\"].apply(\n",
    "            lambda x: np.nan if pd.isna(x)\n",
    "            else 2021 + (x - 1) // 4\n",
    "        )\n",
    "        - d[\"vintage_year\"]\n",
    "    )\n",
    "\n",
    "    d[\"loan_age_bucket\"] = (\n",
    "        pd.cut(\n",
    "            d[\"months_on_book\"],\n",
    "            bins=[0, 12, 36, 60, 120, np.inf],\n",
    "            labels=False,\n",
    "        )\n",
    "        .fillna(0)\n",
    "        .astype(int)\n",
    "    )\n",
    "\n",
    "    d[\"recent_restructure\"] = (\n",
    "        (d[\"is_restructured_loan_enc\"] == 1)\n",
    "        & (d[\"months_since_last_restructure\"].fillna(999) <= 6)\n",
    "    ).astype(int)\n",
    "\n",
    "    # ==========================================================\n",
    "    # 9. Interest Rate Environment\n",
    "    # ==========================================================\n",
    "    rate_map = {\n",
    "        \"Falling\": -1,\n",
    "        \"Stable\": 0,\n",
    "        \"Rising\": 1,\n",
    "    }\n",
    "\n",
    "    d[\"rate_env_enc\"] = (\n",
    "        d[\"interest_rate_environment\"]\n",
    "        .map(rate_map)\n",
    "        .fillna(0)\n",
    "        .astype(int)\n",
    "    )\n",
    "\n",
    "    d[\"rate_stress\"] = (\n",
    "        (d[\"rate_env_enc\"] == 1)\n",
    "        & (d[\"is_fixed_rate_enc\"] == 0)\n",
    "    ).astype(int)\n",
    "\n",
    "    # ==========================================================\n",
    "    # 10. Interaction Features\n",
    "    # ==========================================================\n",
    "    d[\"dpd_x_missed\"] = (\n",
    "        d[\"days_past_due_current\"].fillna(0)\n",
    "        * d[\"missed_payments_last_12m\"].fillna(0)\n",
    "    )\n",
    "\n",
    "    d[\"pd_lift_x_score_detr\"] = (\n",
    "        d[\"pd_lift\"].clip(-10, 50).fillna(0)\n",
    "        * d[\"score_deteriorating\"]\n",
    "    )\n",
    "\n",
    "    d[\"restructured_still_dpd\"] = (\n",
    "        d[\"is_restructured_loan_enc\"]\n",
    "        * d[\"is_delinquent\"]\n",
    "    )\n",
    "\n",
    "    d[\"double_stress\"] = (\n",
    "        d[\"forbearance_history_enc\"]\n",
    "        * d[\"payment_reduction_requested_enc\"]\n",
    "    )\n",
    "\n",
    "    return d\n",
    "\n",
    "\n",
    "# Run\n",
    "df_feat = engineer_features(df_raw)\n",
    "\n",
    "print(f\"Features before engineering : {df_raw.shape[1]}\")\n",
    "print(f\"Features after engineering  : {df_feat.shape[1]}\")\n",
    "print(f\"New features created        : {df_feat.shape[1] - df_raw.shape[1]}\")\n",
    "\n",
    "print(\"\\n Feature engineering completed successfully.\")"
   ]
