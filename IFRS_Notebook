    "# ── Helper: Evaluation Function ─────────────────────────────────────────────\n",
    "def evaluate_model(model, X, y, threshold=0.5, model_name='Model'):\n",
    "    \"\"\"Compute full production metric suite.\"\"\"\n",
    "    if hasattr(model, 'predict_proba'):\n",
    "        y_prob = model.predict_proba(X)[:, 1]\n",
    "    else:\n",
    "        y_prob = model.predict(X)\n",
    "    \n",
    "    y_pred = (y_prob >= threshold).astype(int)\n",
    "    \n",
    "    roc     = roc_auc_score(y, y_prob)\n",
    "    pr_auc  = average_precision_score(y, y_prob)\n",
    "    brier   = brier_score_loss(y, y_prob)\n",
    "    rec     = recall_score(y, y_pred)\n",
    "    prec    = precision_score(y, y_pred, zero_division=0)\n",
    "    f1      = f1_score(y, y_pred)\n",
    "    \n",
    "    # Business metric: Recall @ Top 10% Risk Bucket\n",
    "    n_top = int(len(y) * 0.10)\n",
    "    top_idx = np.argsort(y_prob)[::-1][:n_top]\n",
    "    recall_top10 = y.iloc[top_idx].sum() / y.sum() if y.sum() > 0 else 0\n",
    "    \n",
    "    # Exposure Captured\n",
    "    y_arr = np.array(y)\n",
    "    captured_pct = y_arr[top_idx].sum() / max(y_arr.sum(), 1) * 100\n",
    "    \n",
    "    metrics = {\n",
    "        'model': model_name,\n",
    "        'roc_auc': round(roc, 4),\n",
    "        'pr_auc': round(pr_auc, 4),\n",
    "        'brier': round(brier, 4),\n",
    "        'recall': round(rec, 4),\n",
    "        'precision': round(prec, 4),\n",
    "        'f1': round(f1, 4),\n",
    "        'recall_top10pct': round(recall_top10, 4),\n",
    "        'captured_stage2_top10pct': round(captured_pct, 2)\n",
    "    }\n",
    "    return metrics, y_prob\n",
    "\n",
    "\n",
    "def print_metrics(metrics):\n",
    "    print(f\"  ROC-AUC           : {metrics['roc_auc']:.4f}\")\n",
    "    print(f\"  PR-AUC            : {metrics['pr_auc']:.4f}\")\n",
    "    print(f\"  Brier Score       : {metrics['brier']:.4f}\")\n",
    "    print(f\"  Recall            : {metrics['recall']:.4f}\")\n",
    "    print(f\"  Precision         : {metrics['precision']:.4f}\")\n",
    "    print(f\"  F1 Score          : {metrics['f1']:.4f}\")\n",
    "    print(f\"  Recall@Top10%     : {metrics['recall_top10pct']:.4f}\")\n",
    "    print(f\"  Captured S2@Top10%: {metrics['captured_stage2_top10pct']:.2f}%\")\n",
    "\n",
    "all_results = {}\n"
