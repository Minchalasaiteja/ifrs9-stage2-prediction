    "# ── Production Inference Class ───────────────────────────────────────────────\n",
    "class IFRS9PredictionPipeline:\n",
    "    \"\"\"\n",
    "    Production-ready inference pipeline.\n",
    "    This class is exactly what FastAPI will load at startup.\n",
    "    \n",
    "    Usage:\n",
    "        pipeline = IFRS9PredictionPipeline.load(ARTIFACTS_DIR)\n",
    "        result = pipeline.predict_single(loan_data_dict)\n",
    "        batch_result = pipeline.predict_batch(list_of_loan_dicts)\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, xgb_model, lgb_model, cb_model, imputer,\n",
    "                 le_encoders, shap_explainer, feature_config):\n",
    "        self.xgb = xgb_model\n",
    "        self.lgb = lgb_model\n",
    "        self.cb  = cb_model\n",
    "        self.imputer = imputer\n",
    "        self.le_encoders = le_encoders\n",
    "        self.explainer = shap_explainer\n",
    "        self.config = feature_config\n",
    "        self.all_features = feature_config['all_features']\n",
    "        self.threshold = feature_config['optimal_threshold']\n",
    "        self.weights = feature_config['ensemble_weights']\n",
    "    \n",
    "    @classmethod\n",
    "    def load(cls, artifacts_dir: Path):\n",
    "        \"\"\"Load all artifacts from disk.\"\"\"\n",
    "        artifacts_dir = Path(artifacts_dir)\n",
    "        xgb_m  = joblib.load(artifacts_dir / 'models' / 'xgb_tuned.pkl')\n",
    "        lgb_m  = joblib.load(artifacts_dir / 'models' / 'lgb_tuned.pkl')\n",
    "        imputer_ = joblib.load(artifacts_dir / 'models' / 'imputer.pkl')\n",
    "        le_enc = joblib.load(artifacts_dir / 'models' / 'label_encoders.pkl')\n",
    "        shap_e = joblib.load(artifacts_dir / 'models' / 'shap_explainer.pkl')\n",
    "        \n",
    "        cb_m = CatBoostClassifier()\n",
    "        cb_m.load_model(str(artifacts_dir / 'models' / 'catboost_model.cbm'))\n",
    "        \n",
    "        with open(artifacts_dir / 'feature_config.json') as f:\n",
    "            config = json.load(f)\n",
    "        \n",
    "        return cls(xgb_m, lgb_m, cb_m, imputer_, le_enc, shap_e, config)\n",
    "    \n",
    "    def _preprocess(self, df: pd.DataFrame) -> tuple:\n",
    "        \"\"\"Apply full feature engineering and preprocessing.\"\"\"\n",
    "        # Feature engineering\n",
    "        df_proc = engineer_features(df)\n",
    "        \n",
    "        # Label encode categoricals\n",
    "        for col in self.config['categorical_features']:\n",
    "            le = self.le_encoders[col]\n",
    "            col_le = f'{col}_le'\n",
    "            df_proc[col_le] = df_proc[col].astype(str).apply(\n",
    "                lambda x: le.transform([x])[0] if x in le.classes_ else -1\n",
    "            )\n",
    "        \n",
    "        # Select features & impute\n",
    "        X = df_proc[self.all_features]\n",
    "        X_imp = self.imputer.transform(X)\n",
    "        X_df  = pd.DataFrame(X_imp, columns=self.all_features)\n",
    "        return X_imp, X_df\n",
    "    \n",
    "    def predict_single(self, loan_data: dict, explain: bool = True) -> dict:\n",
    "        \"\"\"\n",
    "        Predict Stage 2 migration for a single loan.\n",
    "        Returns probability, risk tier, decision, and SHAP explanations.\n",
    "        \"\"\"\n",
    "        start_time = time.time()\n",
    "        df_single = pd.DataFrame([loan_data])\n",
    "        X_imp, X_df = self._preprocess(df_single)\n",
    "        \n",
    "        # Ensemble prediction\n",
    "        p_xgb = self.xgb.predict_proba(X_imp)[0, 1]\n",
    "        p_lgb = self.lgb.predict_proba(X_imp)[0, 1]\n",
    "        p_cb  = self.cb.predict_proba(X_df)[0, 1]\n",
    "        \n",
    "        probability = (self.weights['xgboost'] * p_xgb +\n",
    "                       self.weights['lightgbm'] * p_lgb +\n",
    "                       self.weights['catboost'] * p_cb)\n",
    "        \n",
    "        # Risk tier\n",
    "        if probability < 0.10:   risk_tier = 'VERY_LOW'\n",
    "        elif probability < 0.25: risk_tier = 'LOW'\n",
    "        elif probability < 0.50: risk_tier = 'MEDIUM'\n",
    "        elif probability < 0.75: risk_tier = 'HIGH'\n",
    "        else:                    risk_tier = 'VERY_HIGH'\n",
    "        \n",
    "        result = {\n",
    "            'loan_id': loan_data.get('loan_id', 'UNKNOWN'),\n",
    "            'stage2_probability': round(float(probability), 6),\n",
    "            'predicted_stage2': int(probability >= self.threshold),\n",
    "            'risk_tier': risk_tier,\n",
    "            'threshold_used': self.threshold,\n",
    "            'model_scores': {'xgboost': round(float(p_xgb), 6),\n",
    "                            'lightgbm': round(float(p_lgb), 6),\n",
    "                            'catboost': round(float(p_cb), 6)},\n",
    "            'inference_time_ms': round((time.time() - start_time) * 1000, 2)\n",
    "        }\n",
    "        \n",
    "        # SHAP explanations\n",
    "        if explain:\n",
    "            shap_vals = self.explainer.shap_values(X_imp)\n",
    "            result['risk_drivers'] = get_top_risk_drivers(\n",
    "                shap_vals[0], self.all_features, X_imp[0]\n",
    "            )\n",
    "        \n",
    "        return result\n",
    "    \n",
    "    def predict_batch(self, loans: list) -> list:\n",
    "        \"\"\"Predict for a list of loans (batch mode, no SHAP for speed).\"\"\"\n",
    "        df_batch = pd.DataFrame(loans)\n",
    "        X_imp, X_df = self._preprocess(df_batch)\n",
    "        \n",
    "        p_xgb = self.xgb.predict_proba(X_imp)[:, 1]\n",
    "        p_lgb = self.lgb.predict_proba(X_imp)[:, 1]\n",
    "        p_cb  = self.cb.predict_proba(X_df)[:, 1]\n",
    "        \n",
    "        probs = (self.weights['xgboost'] * p_xgb +\n",
    "                 self.weights['lightgbm'] * p_lgb +\n",
    "                 self.weights['catboost'] * p_cb)\n",
    "        \n",
    "        results = []\n",
    "        for i, (loan, prob) in enumerate(zip(loans, probs)):\n",
    "            if prob < 0.10:   rt = 'VERY_LOW'\n",
    "            elif prob < 0.25: rt = 'LOW'\n",
    "            elif prob < 0.50: rt = 'MEDIUM'\n",
    "            elif prob < 0.75: rt = 'HIGH'\n",
    "            else:             rt = 'VERY_HIGH'\n",
    "            results.append({\n",
    "                'loan_id': loan.get('loan_id', f'LOAN_{i}'),\n",
    "                'stage2_probability': round(float(prob), 6),\n",
    "                'predicted_stage2': int(prob >= self.threshold),\n",
    "                'risk_tier': rt\n",
    "            })\n",
    "        return results\n",
    "\n",
    "\n",
    "# ── Test the pipeline ─────────────────────────────────────────────────────────\n",
    "pipeline = IFRS9PredictionPipeline.load(ARTIFACTS_DIR)\n",
    "\n",
    "# Sample loan from test set\n",
    "sample_loan = df_test.iloc[0].to_dict()\n",
    "result = pipeline.predict_single(sample_loan, explain=True)\n",
    "\n",
    "print(\"\\n SAMPLE PREDICTION RESULT:\")\n",
    "print(json.dumps({k:v for k,v in result.items() if k != 'risk_drivers'}, indent=2))\n",
    "print(\"\\n Risk Drivers:\")\n",
    "for d in result['risk_drivers']:\n",
    "    arrow = '⬆️' if d['direction'] == 'INCREASES_RISK' else '⬇️'\n",
    "    print(f\"  #{d['rank']} {arrow} {d['feature']:<40} SHAP={d['shap_impact']:+.4f}\")\n",
    "\n",
    "# Batch test\n",
    "sample_loans = df_test.head(1000).to_dict('records')\n",
    "batch_results = pipeline.predict_batch(sample_loans)\n",
    "tier_counts = pd.Series([r['risk_tier'] for r in batch_results]).value_counts()\n",
    "print(f\"\\n📦 Batch of 1000 loans — Risk Tier Distribution:\")\n",
    "print(tier_counts.to_string())\n",
    "\n",
    "# Save pipeline\n",
    "joblib.dump(pipeline, ARTIFACTS_DIR / 'models' / 'ifrs9_pipeline.pkl')\n",
    "print(\"\\n Full pipeline saved: ifrs9_pipeline.pkl\")\n"
   ]
